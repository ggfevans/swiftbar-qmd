{
  "tasks": {
    "test": "deno test --allow-read --allow-env --allow-net=localhost --allow-write=/tmp",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "check": "deno check qmd.30s.ts lib/**/*.ts tests/**/*.ts"
  },
  "fmt": {
    "exclude": ["docs/", ".github/", "session-report.md", "blockers.md"]
  },
  "lint": {
    "exclude": ["docs/", ".github/"]
  },
  "imports": {
    "@std/yaml": "jsr:@std/yaml@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/testing": "jsr:@std/testing@^1",
    "@std/assert": "jsr:@std/assert@^1",
    "@tobilu/qmd": "npm:@tobilu/qmd@^2.1.0"
  }
}
